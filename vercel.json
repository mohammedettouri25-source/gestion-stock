{
  "version": 2,
  "outputDirectory": "backend/public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php",
      "includeFiles": "backend/**"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
