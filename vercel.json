{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/backend/public/assets/$1"
    },
    {
      "src": "/(.*\\.(?:js|css|png|jpg|jpeg|svg|ico|webmanifest))$",
      "dest": "/backend/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
